rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // bookings: siapa saja bisa buat, siapa saja bisa baca (untuk tracking publik)
    match /bookings/{id} {
      allow create: if true;
      allow read:   if true;
      allow update, delete: if request.auth != null;
    }

    // settings (cars, rekening): public read, auth write
    match /settings/{id} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    match /{doc=**} {
      allow read, write: if false;
    }
  }
}
