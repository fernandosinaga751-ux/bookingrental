rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // bookings: public create, admin read/update/delete
    match /bookings/{bookingId} {
      allow create: if true;
      allow read: if true; // tracking publik bisa baca
      allow update, delete: if request.auth != null;
    }
    
    // cars & settings: public read, admin write
    match /cars/{carId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
