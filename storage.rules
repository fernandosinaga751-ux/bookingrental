rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // invoices: admin upload, public read
    match /invoices/{bookingId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // photos: admin upload, public read
    match /photos/{bookingId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
