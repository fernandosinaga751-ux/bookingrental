{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default"
    }
  ],
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/admin",
        "destination": "/admin-firebase.html"
      },
      {
        "source": "/tracking",
        "destination": "/tracking-firebase.html"
      },
      {
        "source": "/**",
        "destination": "/index-firebase.html"
      }
    ]
  }
}
