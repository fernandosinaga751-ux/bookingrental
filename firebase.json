{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "firestore.rules",
      "storage.rules",
      "firestore.indexes.json",
      "README_SETUP.md"
    ],
    "rewrites": [
      { "source": "/tracking", "destination": "/tracking.html" },
      { "source": "/admin", "destination": "/admin.html" },
      { "source": "/", "destination": "/index.html" }
    ]
  }
}
